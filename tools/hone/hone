#!/usr/bin/env node
// hone — the repo-quality engine CLI (spec: tools/hone/SPEC.md, FROZEN 2026-07-01).
// v1 wave 1 implements `inventory` and `plan`; `work`/`report`/`run` land in wave 2.
// ESM without extension: requires Node >= 22.7 (module-syntax detection). Node 25 tested.
import { parseArgs } from './lib/util.mjs';

const USAGE = `hone — repo-quality engine (v1)

usage: hone <command> [--repo PATH] [options]

commands:
  inventory   run collectors → <repo>/quality/inventory/*.json
              [--repo .] [--cog N] [--window '6 months ago']
  plan        inventory → ranked candidate packets → <repo>/quality/packets/*.yaml
              [--repo .] [--top 20]
  agenda      one strong-model selection call over sensor/ledger/doctrine digests →
              <repo>/quality/AGENDA.{md,json} (+ history, not-chosen aging, selection ledger);
              citations machine-verified, UNVERIFIED items demoted
              [--repo .] [--dry-run] [--challenge] [--doctrine PATH]
  work <id>   execute one packet (maker ≠ judge)
              [--repo .] [--maker claude|codex] [--judge codex|claude] [--dry-run]
  lane        deterministic spine for EXTERNAL (Workflow-substrate) makers/judges;
              engine-run receipts/gates/ledgers only — agent claims never trusted
              (design: SUBSTRATE.md; driver: workflows/hone-lane.js)
    lane emit --packet <id>   gates + in_progress + GREEN BASELINE → maker brief JSON
              [--repo .] [--maker P] [--judge P] [--dry-run]
    lane gate --packet <id>   rungs + touchset gate vs the CURRENT tree → receipts;
              exit 0 only on full green [--repo .] [--maker-summary(-b64)] [--usage(-b64)]
    lane land --packet <id>   green-gate-receipt-bound commit or revert; verdict+usage → ledgers
              [--repo .] (--judge-verdict(-b64) --usage(-b64)) | (--abort --reason TEXT)
  reset <id>  deliberately reopen a terminal packet → status pending (recorded in packet.resets)
              [--repo .] [--to pending] [--force] [--reason TEXT]   (landed requires --force)
  report      compile claim-ledger report → <repo>/quality/reports/
  run         plan→work loop, conflict-aware lanes
              [--repo .] [--n K] [--lanes L]

Per-repo config: <repo>/quality/hone.yaml (falls back to generic JS/TS defaults).
Docs: tools/hone/README.md · spec: tools/hone/SPEC.md
`;

const [cmd, ...rest] = process.argv.slice(2);
const flags = parseArgs(rest);

try {
  switch (cmd) {
    case 'inventory': {
      const { runInventory } = await import('./lib/inventory.mjs');
      await runInventory(flags);
      break;
    }
    case 'plan': {
      const { runPlan } = await import('./lib/plan.mjs');
      await runPlan(flags);
      break;
    }
    case 'agenda': {
      const { runAgenda } = await import('./lib/agenda.mjs');
      await runAgenda(flags);
      break;
    }
    case 'work': {
      const { runWork } = await import('./lib/work.mjs');
      await runWork(flags);
      break;
    }
    case 'lane': {
      const { runLane } = await import('./lib/lane.mjs');
      await runLane(flags);
      break;
    }
    case 'reset': {
      const { runReset } = await import('./lib/reset.mjs');
      await runReset(flags);
      break;
    }
    case 'report': {
      const { runReport } = await import('./lib/report.mjs');
      await runReport(flags);
      break;
    }
    case 'run': {
      const { runLoop } = await import('./lib/run.mjs');
      await runLoop(flags);
      break;
    }
    case 'help':
    case '--help':
    case undefined:
      process.stdout.write(USAGE);
      process.exit(cmd ? 0 : 2);
      break;
    default:
      console.error(`hone: unknown command '${cmd}'\n`);
      process.stdout.write(USAGE);
      process.exit(2);
  }
} catch (e) {
  console.error(`hone ${cmd}: FATAL: ${e.message}`);
  if (process.env.HONE_DEBUG) console.error(e.stack);
  process.exit(1);
}
