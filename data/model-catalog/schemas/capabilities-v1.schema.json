{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tnunamak/minnows/data/model-catalog/schemas/capabilities-v1.schema.json",
  "title": "model-catalog capabilities document v1",
  "description": "Per provider/model/surface effort and mode validity. Facts only — no recommended operating points.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schema_version",
    "kind",
    "retrieved_at",
    "source_urls",
    "surfaces"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
    "schema_version": { "type": "integer", "const": 1 },
    "kind": { "type": "string", "const": "capabilities" },
    "retrieved_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "source_urls": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 8 }
    },
    "source_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" }
    },
    "notes": { "type": "string" },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "provider",
          "model",
          "surface",
          "valid_efforts",
          "unsupported_behavior"
        ],
        "properties": {
          "provider": {
            "type": "string",
            "enum": ["anthropic", "openai", "xai", "google", "other"]
          },
          "model": { "type": "string", "minLength": 1 },
          "surface": {
            "type": "string",
            "enum": [
              "api",
              "codex_cli",
              "claude_code",
              "grok_cli",
              "build_agent",
              "other"
            ]
          },
          "valid_efforts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "none",
                "minimal",
                "low",
                "medium",
                "high",
                "xhigh",
                "max"
              ]
            }
          },
          "default_effort": { "type": "string" },
          "unsupported_behavior": {
            "type": "string",
            "enum": ["hard_fail", "warn_passthrough"]
          },
          "aliases": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "modes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode_id"],
              "properties": {
                "mode_id": { "type": "string" },
                "notes": { "type": "string" },
                "cost_multiplier": { "type": "number" },
                "speed_multiplier": { "type": "number" }
              }
            }
          },
          "source_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        }
      }
    },
    "missing": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
