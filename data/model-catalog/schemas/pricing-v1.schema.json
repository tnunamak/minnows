{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tnunamak/minnows/data/model-catalog/schemas/pricing-v1.schema.json",
  "title": "model-catalog pricing table v1",
  "description": "Compatible with tokensmash pricing tables (api_usd | codex_credits). Never invent rates; omit unknown models.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schema_version",
    "kind",
    "agent",
    "retrieved_at",
    "source_urls",
    "models",
    "match"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$",
      "description": "Stable table id, e.g. anthropic-api-2026-07"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "api_usd",
        "codex_credits"
      ],
      "description": "api_usd = dollars per 1M tokens; codex_credits = Codex credit units per 1M tokens"
    },
    "agent": {
      "type": "string",
      "enum": [
        "claude-code",
        "codex",
        "grok"
      ],
      "description": "Session/agent family this table applies to when resolving model ids"
    },
    "retrieved_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "source_urls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 8
      }
    },
    "notes": {
      "type": "string"
    },
    "models": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fresh_input_per_m",
          "cache_read_per_m",
          "cache_write_per_m",
          "output_per_m"
        ],
        "properties": {
          "fresh_input_per_m": {
            "type": "number",
            "minimum": 0
          },
          "cache_read_per_m": {
            "type": "number",
            "minimum": 0
          },
          "cache_write_per_m": {
            "type": "number",
            "minimum": 0
          },
          "output_per_m": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "match": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pattern",
          "model"
        ],
        "properties": {
          "pattern": {
            "type": "string",
            "minLength": 1
          },
          "model": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "description": "Ordered substring match rules; first win. Each model must exist in models."
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]+$"
      },
      "description": "Ids from SOURCES.json that back this pricing table"
    }
  }
}
