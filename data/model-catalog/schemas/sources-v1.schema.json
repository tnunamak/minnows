{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tnunamak/minnows/data/model-catalog/schemas/sources-v1.schema.json",
  "title": "model-catalog provenance registry v1",
  "description": "Canonical source registry. Payload source_ids[] and row source_id must resolve here.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schema_version",
    "retrieved_at",
    "sources"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "const": "model-catalog-sources"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "retrieved_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "description": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "url",
          "title",
          "publisher",
          "retrieved_at",
          "kind"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]+$",
            "minLength": 3
          },
          "url": {
            "type": "string",
            "minLength": 8
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "publisher": {
            "type": "string",
            "minLength": 1
          },
          "published": {
            "type": [
              "string",
              "null"
            ]
          },
          "retrieved_at": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "vendor_blog",
              "vendor_docs",
              "third_party_eval",
              "academic",
              "other",
              "digitized_chart",
              "local_eval"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
