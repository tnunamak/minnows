{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tnunamak/minnows/data/schemas/index-v1.schema.json",
  "title": "minnows data packs index",
  "description": "data/index.json — discovery document for latest pack tags and ready-made URLs",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "updated_at", "repo", "packs"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "type": "integer", "const": 1 },
    "updated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "repo": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
      "description": "GitHub owner/repo without .git suffix"
    },
    "packs": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "latest_tag",
          "description",
          "readme",
          "releases",
          "pack_json",
          "tarball",
          "tree"
        ],
        "properties": {
          "latest_tag": {
            "type": "string",
            "pattern": "^data-[a-z][a-z0-9-]*-v[0-9]+\\.[0-9]+\\.[0-9]+$"
          },
          "description": { "type": "string", "minLength": 1 },
          "readme": { "type": "string", "format": "uri" },
          "releases": { "type": "string", "format": "uri" },
          "pack_json": { "type": "string", "format": "uri" },
          "tarball": { "type": "string", "format": "uri" },
          "tree": { "type": "string", "format": "uri" }
        }
      }
    }
  }
}
